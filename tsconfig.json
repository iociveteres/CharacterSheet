{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "skipLibCheck": true,
    "moduleDetection": "force"
  },

  "include": ["ui/static/js"]
}